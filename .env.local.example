OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Keep false for low-rate-limit accounts. Set true only if your account has enough RPM/TPM.
OPENAI_ENABLE_WEB_SEARCH=false

# Public production quota for real OpenAI analysis. Defaults to 20 when omitted.
OPENAI_DAILY_QUOTA=20

# Required in production when OPENAI_API_KEY is configured.
# Create a Vercel Upstash Redis integration and copy its REST credentials here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional. Use this when Node.js cannot reach api.openai.com directly.
# Example: OPENAI_PROXY_URL=http://127.0.0.1:7892
OPENAI_PROXY_URL=
